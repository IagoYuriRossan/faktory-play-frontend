{
  "openapi": "3.0.1",
  "info": {
    "title": "Faktory Play API — Spec para Frontend AI",
    "version": "1.0.0",
    "description": "Spec mínima em português para o agente frontend AI."
  },
  "servers": [
    { "url": "http://localhost:3001", "description": "Servidor local (dev)" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": ["string", "null"] },
          "role": { "type": "string" },
          "companyId": { "type": ["string", "null"] },
          "allowedTrails": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Trail": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "durationMonths": { "type": ["number", "null"] }
        }
      },
      "UserTrail": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "trailId": { "type": "string" },
          "companyId": { "type": ["string", "null"] },
          "status": { "type": "string" },
          "totalProgress": { "type": "number" }
        }
      },
      "CompanyTrailsWithUsers": {
        "type": "object",
        "properties": {
          "companyId": { "type": "string" },
          "trails": { "type": "array", "items": { "type": "object" } }
        }
      },
      "CompanyReport": {
        "type": "object",
        "properties": {
          "companyId": { "type": "string" },
          "generatedAt": { "type": "string", "format": "date-time" },
          "trails": { "type": "array", "items": { "type": "object" } }
        }
      }
    }
  },
  "paths": {
    "/api/openapi.json": {
      "get": {
        "summary": "OpenAPI JSON gerado",
        "responses": {
          "200": {
            "description": "Spec JSON",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        }
      }
    },
    "/api/trails": {
      "get": {
        "summary": "Listar trilhas permitidas",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de trilhas",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Trail" } } } }
          }
        }
      }
    },
    "/api/trails/{id}": {
      "get": {
        "summary": "Obter trilha por id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Trilha encontrada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Trail" } } } },
          "403": { "description": "Acesso negado" },
          "404": { "description": "Trilha não encontrada" }
        }
      }
    },
    "/api/companies/{id}/trails-with-users": {
      "get": {
        "summary": "Trilhas da empresa com usuários e progresso",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Trilhas com usuários", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CompanyTrailsWithUsers" } } } } }
      }
    },
    "/api/companies/{id}/report": {
      "get": {
        "summary": "Relatório consolidado por empresa",
        "parameters": [ { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } } ],
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Relatório por empresa", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CompanyReport" } } } } }
      }
    },
    "/api/users": {
      "get": {
        "summary": "Listar usuários",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "Lista de usuários", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/User" } } } } } }
      }
    }
  }
}
